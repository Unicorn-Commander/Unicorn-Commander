# =============================================================================
# Unicorn Commander - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------------------------------------
# PostgreSQL (shared database server)
# -----------------------------------------------------------------------------
POSTGRES_USER=unicorn
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_HOST=unicorn-postgresql
POSTGRES_PORT=5432

# Ops-Center uses unicorn_db, Brigade uses brigade_db
OPS_CENTER_DB=unicorn_db
BRIGADE_DB=brigade_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://unicorn-redis:6379

# -----------------------------------------------------------------------------
# Keycloak SSO
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production
KEYCLOAK_REALM=uchub
KEYCLOAK_URL=http://unicorn-keycloak:8080

# Ops-Center OAuth client
OPS_CENTER_CLIENT_ID=ops-center
OPS_CENTER_CLIENT_SECRET=change-me-in-production

# Brigade OAuth client
BRIGADE_CLIENT_ID=brigade
BRIGADE_CLIENT_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# Brigade Service Key (for Brigade → Ops-Center API calls)
# -----------------------------------------------------------------------------
BRIGADE_SERVICE_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# LLM Providers (optional — needed for AI features)
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Billing (optional — set BILLING_ENABLED=false to disable)
# -----------------------------------------------------------------------------
BILLING_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# LAGO_API_KEY=...

# -----------------------------------------------------------------------------
# AI Services (optional — enable with: docker compose --profile ai up -d)
# -----------------------------------------------------------------------------
# Embeddings service
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DEVICE=cpu

# HuggingFace token (needed for gated models like WhisperX)
# HF_TOKEN=hf_...

# vLLM endpoint (for model-manager service)
# VLLM_URL=http://unicorn-vllm:8000

# -----------------------------------------------------------------------------
# Federation (optional — for multi-node deployments)
# -----------------------------------------------------------------------------
# FEDERATION_ENABLED=false
# FEDERATION_KEY=change-me-in-production
# FEDERATION_PEERS=
